<?xml version="1.0" encoding="UTF-8"?>
<!-- Grain time-stretch 2x: 4 s ramped sawtooth becomes 8 s (384000 frames). -->
<SActionScript version="1" name="grain_time_stretch_2x">

  <setup project="new"/>

  <actions>
    <add-track index="-1"/>

    <!-- 4 s sawtooth (192000 frames) -->
    <add-sample trackIndex="0" filePath="../test_sawtooth.wav" timePos="0"/>

    <!-- 2x stretch: 192000 x 2 = 384000 frames -->
    <resize-clip clip="0,0" startTime="0" startOffset="0"
                 duration="384000" loopLength="0" stretch="2.0"/>

    <render filename="grain_time_stretch_2x.wav" format="wav" quality="10"/>

    <!-- Clip region: stretched ramp keeps its RMS (~0.25-0.27) -->
    <assert-audio-energy filename="grain_time_stretch_2x.wav"
                         startFrame="0" frameCount="384000"
                         minRms="0.20" maxRms="0.32"/>

    <!-- Past the stretched clip end: silence -->
    <assert-audio-energy filename="grain_time_stretch_2x.wav"
                         startFrame="384000" frameCount="48000"
                         minRms="0.0" maxRms="0.005"/>

    <assert-audio-peak filename="grain_time_stretch_2x.wav" maxPeak="0.995"/>

    <screenshot filename="grain_time_stretch_2x_timeline.png" resolution="50%"/>
  </actions>

  <assertions>
    <assert-track-count equals="1"/>
  </assertions>

</SActionScript>

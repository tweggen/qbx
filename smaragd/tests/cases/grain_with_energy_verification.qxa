<?xml version="1.0" encoding="UTF-8"?>
<!-- Grain 1.5x stretch with region-scoped acoustic verification. -->
<SActionScript version="1" name="grain_with_energy_verification">

  <setup project="new"/>

  <actions>
    <add-track index="-1"/>

    <!-- 4 s sawtooth (192000 frames) -->
    <add-sample trackIndex="0" filePath="../test_sawtooth.wav" timePos="0"/>

    <!-- 1.5x stretch: 192000 x 1.5 = 288000 frames -->
    <resize-clip clip="0,0" startTime="0" startOffset="0"
                 duration="288000" loopLength="0" stretch="1.5"/>

    <render filename="grain_energy_verification.wav" format="wav" quality="10"/>

    <!-- Clip region: stretched ramp keeps its RMS (~0.25-0.27) -->
    <assert-audio-energy filename="grain_energy_verification.wav"
                         startFrame="0" frameCount="288000"
                         minRms="0.20" maxRms="0.32"/>

    <!-- Past the stretched clip end: silence -->
    <assert-audio-energy filename="grain_energy_verification.wav"
                         startFrame="288000" frameCount="48000"
                         minRms="0.0" maxRms="0.005"/>

    <assert-audio-peak filename="grain_energy_verification.wav" maxPeak="0.995"/>

    <screenshot filename="grain_energy_verification_timeline.png" resolution="50%"/>
  </actions>

  <assertions>
    <assert-track-count equals="1"/>
  </assertions>

</SActionScript>

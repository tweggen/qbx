<?xml version="1.0" encoding="UTF-8"?>
<!--
  Grain stretch + track volume: track 0 plays a 1.5x-stretched clip at -6 dB,
  track 1 plays the plain clip at 0 dB, placed later so the regions do not
  overlap. The -6 dB region must come out at roughly half the RMS of the
  0 dB region (~0.125 vs ~0.25).
-->
<SActionScript version="1" name="grain_with_volume_control">

  <setup project="new"/>

  <actions>
    <add-track index="-1"/>
    <add-track index="-1"/>

    <add-sample trackIndex="0" filePath="../test_sawtooth.wav" timePos="0"/>
    <add-sample trackIndex="1" filePath="../test_sawtooth.wav" timePos="480000"/>

    <!-- 1.5x stretch on the first clip -->
    <resize-clip clip="0,0" startTime="0" startOffset="0"
                 duration="288000" loopLength="0" stretch="1.5"/>

    <set-track-volume trackIndex="0" volume="-6.0"/>
    <set-track-volume trackIndex="1" volume="0.0"/>

    <render filename="grain_with_volume_control.wav" format="wav" quality="10"/>

    <!-- Track 0 region at -6 dB: about half the ramp RMS -->
    <assert-audio-energy filename="grain_with_volume_control.wav"
                         startFrame="0" frameCount="288000"
                         minRms="0.09" maxRms="0.17"/>

    <!-- Track 1 region at 0 dB: full ramp RMS -->
    <assert-audio-energy filename="grain_with_volume_control.wav"
                         startFrame="480000" frameCount="192000"
                         minRms="0.20" maxRms="0.32"/>

    <assert-audio-peak filename="grain_with_volume_control.wav" maxPeak="0.995"/>

    <screenshot filename="grain_with_volume_control_timeline.png" resolution="50%"/>
  </actions>

  <assertions>
    <assert-track-count equals="2"/>
  </assertions>

</SActionScript>

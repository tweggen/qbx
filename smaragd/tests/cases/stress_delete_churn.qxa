<?xml version="1.0" encoding="UTF-8"?>
<!--
  Stress: interleave clip DELETION with stretch/split/slip churn on clips that
  reference the same sample. Each edit schedules async buildCapture_ jobs on the
  8-worker revalidator; deleting the clip (remove-sample) releases the track's
  SLink reference while a worker job may still hold one and be mid-buildCapture_.

  This is the use-after-free path: with a non-atomic refcount the worker's
  revalRemoveRef races the GUI-thread delete and can double-free / prematurely
  delete the SCut. Must not crash whatever the interleaving.
-->
<SActionScript version="1" name="stress_delete_churn">

  <setup project="new"/>

  <actions>
    <add-track index="-1"/>

    <!-- Round 1 -->
    <add-sample trackIndex="0" filePath="../test_sawtooth.wav" timePos="0"/>
    <resize-clip clip="0,0" startTime="0" startOffset="0" duration="96000" loopLength="0" stretch="1.5"/>
    <resize-clip clip="0,0" startTime="0" startOffset="40000" duration="80000" loopLength="0" stretch="0.5"/>
    <split-clip clip="0,0" splitTime="24000"/>
    <resize-clip clip="0,1" startTime="24000" startOffset="30000" duration="48000" loopLength="0" stretch="2.0"/>
    <remove-sample trackIndex="0" clipIndex="1"/>
    <remove-sample trackIndex="0" clipIndex="0"/>

    <!-- Round 2 -->
    <add-sample trackIndex="0" filePath="../test_sawtooth.wav" timePos="0"/>
    <resize-clip clip="0,0" startTime="0" startOffset="0" duration="120000" loopLength="0" stretch="2.5"/>
    <resize-clip clip="0,0" startTime="0" startOffset="60000" duration="60000" loopLength="0" stretch="0.75"/>
    <split-clip clip="0,0" splitTime="30000"/>
    <resize-clip clip="0,0" startTime="0" startOffset="0" duration="30000" loopLength="0" stretch="1.25"/>
    <remove-sample trackIndex="0" clipIndex="0"/>
    <remove-sample trackIndex="0" clipIndex="0"/>

    <!-- Round 3 -->
    <add-sample trackIndex="0" filePath="../test_sawtooth.wav" timePos="0"/>
    <resize-clip clip="0,0" startTime="0" startOffset="0" duration="96000" loopLength="0" stretch="1.5"/>
    <split-clip clip="0,0" splitTime="48000"/>
    <resize-clip clip="0,1" startTime="48000" startOffset="70000" duration="48000" loopLength="0" stretch="3.0"/>
    <remove-sample trackIndex="0" clipIndex="0"/>
    <resize-clip clip="0,0" startTime="48000" startOffset="80000" duration="24000" loopLength="0" stretch="0.5"/>
    <remove-sample trackIndex="0" clipIndex="0"/>

    <!-- Keep one clip and render to keep workers alive to drain the queue -->
    <add-sample trackIndex="0" filePath="../test_sawtooth.wav" timePos="0"/>
    <resize-clip clip="0,0" startTime="0" startOffset="0" duration="96000" loopLength="0" stretch="1.5"/>
    <render filename="delete_churn_final.wav" format="wav" quality="10"/>
  </actions>

  <assertions>
    <assert-track-count equals="1"/>
  </assertions>

</SActionScript>

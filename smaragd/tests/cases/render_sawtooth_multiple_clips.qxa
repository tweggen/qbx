<?xml version="1.0" encoding="UTF-8"?>
<SActionScript version="1" name="render_sawtooth_multiple_clips">

  <setup project="new"/>

  <actions>
    <!-- Create a track -->
    <add-track index="-1"/>

    <!-- Add the sawtooth sample at position 0 -->
    <add-sample trackIndex="0" filePath="../test_sawtooth.wav" timePos="0"/>

    <!-- Add the same sample again at position 1 second -->
    <add-sample trackIndex="0" filePath="../test_sawtooth.wav" timePos="48000/48000"/>

    <!-- Add the same sample a third time at position 2 seconds -->
    <add-sample trackIndex="0" filePath="../test_sawtooth.wav" timePos="96000/48000"/>

    <!-- Render the project (3 seconds of audio: three copies of sawtooth start concatenated) -->
    <render filename="render_multiple_clips.wav" format="wav" quality="10"/>

    <!-- Screenshot showing all three clips on the timeline -->
    <screenshot filename="render_multiple_clips_timeline.png" resolution="50%"/>

    <!-- Zoomed out view to see the full extent -->
    <screenshot filename="render_multiple_clips_full.png" resolution="1600x400"/>
  </actions>

  <assertions>
    <!-- Verify all three samples were added to the track -->
    <assert-track-count equals="1"/>
  </assertions>

</SActionScript>

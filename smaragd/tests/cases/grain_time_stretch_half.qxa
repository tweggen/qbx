<?xml version="1.0" encoding="UTF-8"?>
<!-- Grain time-compress 0.5x: 4 s ramped sawtooth becomes 2 s (96000 frames). -->
<SActionScript version="1" name="grain_time_stretch_half">

  <setup project="new"/>

  <actions>
    <add-track index="-1"/>

    <!-- 4 s sawtooth (192000 frames) -->
    <add-sample trackIndex="0" filePath="../test_sawtooth.wav" timePos="0"/>

    <!-- 0.5x stretch: 192000 x 0.5 = 96000 frames -->
    <resize-clip clip="0,0" startTime="0" startOffset="0"
                 duration="96000" loopLength="0" stretch="0.5"/>

    <render filename="grain_time_stretch_half.wav" format="wav" quality="10"/>

    <!-- Clip region: compressed ramp keeps its RMS (~0.25-0.27) -->
    <assert-audio-energy filename="grain_time_stretch_half.wav"
                         startFrame="0" frameCount="96000"
                         minRms="0.20" maxRms="0.32"/>

    <!-- Past the compressed clip end: silence -->
    <assert-audio-energy filename="grain_time_stretch_half.wav"
                         startFrame="96000" frameCount="48000"
                         minRms="0.0" maxRms="0.005"/>

    <assert-audio-peak filename="grain_time_stretch_half.wav" maxPeak="0.995"/>

    <screenshot filename="grain_time_stretch_half_timeline.png" resolution="50%"/>
  </actions>

  <assertions>
    <assert-track-count equals="1"/>
  </assertions>

</SActionScript>

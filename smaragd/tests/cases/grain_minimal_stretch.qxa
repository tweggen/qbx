<?xml version="1.0" encoding="UTF-8"?>
<SActionScript version="1" name="grain_minimal_stretch">

  <setup project="new"/>

  <actions>
    <!-- Minimal grain time-stretching test -->

    <!-- Create a track -->
    <add-track index="-1"/>

    <!-- Add the sawtooth sample -->
    <add-sample trackIndex="0" filePath="../test_sawtooth.wav" timePos="0"/>

    <!-- Apply a subtle 1.25x time-stretch -->
    <!-- This activates grain overlap-add with a moderate stretch factor -->
    <!-- Duration: 21.8s × 1.25 = ~27.25s -->
    <resize-clip clip="0/0" startTime="0" startOffset="0" duration="1800000/48000" loopLength="0" stretch="1.25"/>

    <!-- Render the grain-processed audio -->
    <render filename="grain_minimal_stretch.wav" format="wav" quality="10"/>

    <!-- Acoustic verification: ensure grain processing preserved audio quality -->
    <!-- Sawtooth energy should be in healthy range (not silent, not clipped) -->
    <assert-audio-energy filename="grain_minimal_stretch.wav" minRms="0.05" maxRms="0.90"/>

    <!-- Peak amplitude should not clip (grain windowing may slightly reduce peak) -->
    <assert-audio-peak filename="grain_minimal_stretch.wav" maxPeak="0.995"/>

    <!-- Screenshot showing the stretched timeline -->
    <screenshot filename="grain_minimal_stretch_timeline.png" resolution="50%"/>
  </actions>

  <assertions>
    <assert-track-count equals="1"/>
  </assertions>

</SActionScript>

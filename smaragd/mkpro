
#!/bin/bash
NAME=smaragd
echo "# Project file generated by shell script." >$NAME.pro
echo HEADERS = $(find . -name "*.h") >>$NAME.pro
echo SOURCES = $( (find . -name "*.cc"; find . -name "*.cpp") | grep -v "moc_") >>$NAME.pro
echo QT += xml widgets >>$NAME.pro
echo TARGET = $NAME >>$NAME.pro
echo INCLUDEPATH = include main/include tw303a/include >>$NAME.pro
echo CONFIG = c++11 debug warn_on qt thread x11 >>$NAME.pro

echo DESTDIR=bin >>$NAME.pro
echo OBJECTS_DIR=obj >>$NAME.pro
echo MOC_DIR=generated >>$NAME.pro

# Mac
#echo QMAKE_CXXFLAGS += -FCoreAudio -FCoreServices >>$NAME.pro
#echo QMAKE_LIBS += -framework AudioUnit -framework CoreAudio -framework CoreServices >>$NAME.pro

# Linux
echo QMAKE_CXXFLAGS += -DQBX_LINUX_ALSA=1 >>$NAME.pro
echo QMAKE_LIBS += -lasound >>$NAME.pro
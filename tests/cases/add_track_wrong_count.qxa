<?xml version="1.0" encoding="UTF-8"?>
<SActionScript version="1" name="add_track_wrong_count">

  <!-- Setup: start with a new project -->
  <setup project="new"/>

  <!-- Add a track -->
  <actions>
    <add-track index="-1"/>
  </actions>

  <!-- Assertion: verify wrong count (should fail) -->
  <assertions>
    <assert-track-count equals="2"/>
  </assertions>

</SActionScript>

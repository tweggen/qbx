<?xml version="1.0" encoding="UTF-8"?>
<SActionScript version="1" name="add_track_golden">

  <!-- Setup: start with a new project -->
  <setup project="new"/>

  <!-- Add a track -->
  <actions>
    <add-track index="-1"/>
  </actions>

  <!-- Assertion: verify track count (golden file path must be absolute or relative to cwd) -->
  <assertions>
    <assert-track-count equals="1"/>
  </assertions>

</SActionScript>

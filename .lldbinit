# LLDB initialization script for Smaragd debugging
# Source with: lldb -s .lldbinit ./smaragd/build/bin/smaragd.app/Contents/MacOS/smaragd

# Map source file paths so LLDB can find them during debugging
# If building in a different directory, update these paths accordingly
settings set target.source-map /Users/tweggen/coding/github/qbx/smaragd /Users/tweggen/coding/github/qbx/smaragd

# Enable better formatting
settings set target.process.follow-fork-mode child
settings set target.process.stop-on-exec true

# Show more context in backtraces
settings set target.frame-format "frame #${frame.index}: ${frame.pc}{ ${module.file.basename}\`${function.name}{${function.pc-offset}}}{ at ${line.file.basename}:${line.number}{:${line.column}}}\n"
